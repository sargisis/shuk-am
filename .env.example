NEXT_PUBLIC_TELEGRAM_URL=https://t.me/shuk_am
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe TEST keys — https://dashboard.stripe.com/test/apikeys
# sk_test_... (full secret) or rk_test_... (restricted — needs Checkout permission)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Test checkout currency (usd recommended for test accounts; amd when bank supports it)
STRIPE_CURRENCY=usd
# AMD → USD for test only, e.g. 400 AMD ≈ 1 USD
STRIPE_AMD_PER_USD=400
